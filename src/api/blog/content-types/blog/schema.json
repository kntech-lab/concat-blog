{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog",
    "description": "Concat SEO blog post flat schema"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "excerpt": { "type": "text" },
    "content": { "type": "richtext", "required": true },
    "publish": { "type": "boolean", "default": false },
    "cover_image_url": { "type": "text" },
    "keyword": { "type": "string" },
    "blog_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::blog-category.blog-category",
      "inversedBy": "blogs"
    },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo-meta" },
    "tags": { "type": "json" },
    "source_meta": { "type": "json" }
  }
}
