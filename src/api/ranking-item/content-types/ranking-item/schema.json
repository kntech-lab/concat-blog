{
  "kind": "collectionType",
  "collectionName": "ranking_items",
  "info": {
    "singularName": "ranking-item",
    "pluralName": "ranking-items",
    "displayName": "榜单条目",
    "description": "榜单中的条目行"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "ranking": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::ranking.ranking",
      "inversedBy": "items",
      "required": true
    },
    "rank": {
      "type": "integer",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "avatar": {
      "type": "string"
    },
    "follower": {
      "type": "string"
    },
    "followerLabel": {
      "type": "string",
      "default": "Instagram Followers"
    },
    "type": {
      "type": "string"
    },
    "typeLabel": {
      "type": "string",
      "default": "Type"
    },
    "gender": {
      "type": "string"
    },
    "genderLabel": {
      "type": "string",
      "default": "Gender"
    },
    "bio": {
      "type": "text"
    },
    "email": {
      "type": "component",
      "repeatable": false,
      "component": "shared.cta-item"
    },
    "profileLink": {
      "type": "component",
      "repeatable": false,
      "component": "shared.cta-item"
    },
    "profilePlatform": {
      "type": "enumeration",
      "enum": [
        "instagram",
        "youtube",
        "tiktok",
        "x",
        "linkedin",
        "pinterest",
        "website"
      ],
      "default": "instagram"
    },
    "score": {
      "type": "decimal"
    },
    "externalUrl": {
      "type": "string"
    },
    "highlightTags": {
      "type": "json"
    }
  }
}
